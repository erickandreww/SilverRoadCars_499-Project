<section class="car-detail-page">

  <div class="car-detail-layout">
    <div class="car-detail-img">
      <% if (vehicle.imageUrl) { %>
        <img src="<%= vehicle.imageUrl %>" alt="<%= vehicle.brand %> <%= vehicle.model %>">
      <% } else { %>
        <div class="vehicle-card-no-img">No Image</div>
      <% } %>
      <span class="availability-badge avail-<%= vehicle.availabilityStatus %>">
        <%= vehicle.availabilityStatus %>
      </span>
    </div>

    <div class="car-detail-info">
      <h1><%= vehicle.brand %> <%= vehicle.model %> <span class="car-year">(<%= vehicle.year %>)</span></h1>

      <p class="vehicle-price large">$<%= parseFloat(vehicle.dailyPrice).toFixed(2) %><span>/day</span></p>

      <table class="car-specs-table">
        <tr><th>Category</th><td><%= vehicle.category || '—' %></td></tr>
        <tr><th>Color</th><td><%= vehicle.color || '—' %></td></tr>
        <tr><th>Transmission</th><td><%= vehicle.transmission || '—' %></td></tr>
        <tr><th>Fuel Type</th><td><%= vehicle.fuelType || '—' %></td></tr>
        <tr><th>Seats</th><td><%= vehicle.seats || '—' %></td></tr>
        <tr><th>Mileage</th><td><%= vehicle.mileage ? vehicle.mileage.toLocaleString() + ' km' : '—' %></td></tr>
        <tr><th>Plate</th><td style="text-transform:uppercase;"><%= vehicle.plate || '—' %></td></tr>
      </table>

      <% if (vehicle.availabilityStatus === 'available') { %>
        <% if (locals.sessionUser && sessionUser.role === 'client') { %>
          <a href="/clients/rent/<%= vehicle.vehicleId %>" class="btn-primary" style="display:inline-block; text-decoration:none; margin-top:1.5rem;">Rent This Car</a>
        <% } else { %>
          <a href="/login/loginClient" class="btn-primary" style="display:inline-block; text-decoration:none; margin-top:1.5rem;">Login to Rent</a>
        <% } %>
      <% } else { %>
        <p class="unavailable-msg">This vehicle is currently not available for rental.</p>
      <% } %>
    </div>
  </div>

  <!-- Reviews -->
  <div class="reviews-section">
    <div class="reviews-header">
      <h2>Customer Reviews</h2>
      <% if (avgRating) { %>
        <div class="avg-rating">
          <span class="avg-stars"><%= '★'.repeat(Math.round(avgRating)) %><%= '☆'.repeat(5 - Math.round(avgRating)) %></span>
          <span class="avg-number"><%= parseFloat(avgRating).toFixed(1) %> / 5</span>
          <span class="avg-count">(<%= reviews.length %> review<%= reviews.length !== 1 ? 's' : '' %>)</span>
        </div>
      <% } %>
    </div>

    <% if (reviews.length > 0) { %>
      <div class="reviews-list">
        <% reviews.forEach(review => { %>
          <div class="review-item">
            <div class="review-meta">
              <% if (review.clientAvatar) { %>
                <img src="<%= review.clientAvatar %>" alt="<%= review.clientName %>" class="review-avatar">
              <% } else { %>
                <div class="review-avatar-placeholder"><%= review.clientName.charAt(0).toUpperCase() %></div>
              <% } %>
              <div>
                <strong class="review-author"><%= review.clientName %></strong>
                <span class="review-date"><%= new Date(review.createdAt).toLocaleDateString() %></span>
              </div>
              <div class="review-stars"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></div>
            </div>
            <% if (review.comment) { %>
              <p class="review-comment"><%= review.comment %></p>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="no-reviews">No reviews yet. Be the first to review this vehicle!</p>
    <% } %>
  </div>

</section>
