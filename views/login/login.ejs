<div class="auth-page">
  <div class="auth-card">
    <h1>Login</h1>

    <% if (error) { %>
      <p class="auth-error"><%= error %></p>
    <% } %>
    <div class="auth-options">
      <a href="/login/loginClient" class="btn-secondary">Login as Client</a>
      <a href="/login/loginUser" class="btn-secondary">Login as User</a>
    </div>
  </div>
</div>