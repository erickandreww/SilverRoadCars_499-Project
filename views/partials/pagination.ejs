<% if (pagination && pagination.totalPages > 1) { %>
  <% const queryPrefix = pagination.queryString ? pagination.queryString + "&" : ""; %>

  <nav class="pagination" aria-label="Pagination">
    <% if (pagination.hasPrevious) { %>
      <a href="?<%= queryPrefix %>page=<%= pagination.previousPage %>" class="pagination-link">
        Previous
      </a>
    <% } %>

    <% for (let i = 1; i <= pagination.totalPages; i++) { %>
      <a
        href="?<%= queryPrefix %>page=<%= i %>"
        class="pagination-link <%= pagination.page === i ? 'active' : '' %>"
      >
        <%= i %>
      </a>
    <% } %>

    <% if (pagination.hasNext) { %>
      <a href="?<%= queryPrefix %>page=<%= pagination.nextPage %>" class="pagination-link">
        Next
      </a>
    <% } %>
  </nav>
<% } %>