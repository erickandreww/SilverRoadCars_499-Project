<% if (typeof title !== 'undefined' && title) { %>
  <h1><%= title %></h1>
<% } else { %>
  <h1>Client Profile</h1>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
  <p class="error"><%= error %></p>
<% } %>

<section class="editProfile">
  <h2>Edit Your Profile</h2>
  <form action="/clients/profile/edit" method="POST" enctype="multipart/form-data">
    <div class="form-group">
      <label for="clientName">Name:</label>
      <input type="text" id="clientName" name="clientName" value="<%= sessionUser.clientName %>" required>
    </div>
    <div class="form-group">
      <label for="clientEmail">Email:</label>
      <input type="email" id="clientEmail" name="clientEmail" value="<%= sessionUser.clientEmail %>" required>
    </div>
    <div class="form-group">
      <label for="clientPhone">Phone:</label>
      <input type="text" id="clientPhone" name="clientPhone" value="<%= sessionUser.clientPhone %>" required>
    </div>
    <div class="form-group">
      <label for="clientAddress">Address:</label>
      <input type="text" id="clientAddress" name="clientAddress" value="<%= sessionUser.clientAddress %>" required>
    </div>
    <div class="form-group">
      <label for="clientAvatar">Profile Picture:</label>
      <% if (sessionUser.clientAvatar) { %>
        <img src="<%= sessionUser.clientAvatar %>" alt="Current Avatar" width="100" height="100" style="border-radius: 50%; display: block; margin-bottom: 10px;">
      <% } %>
      <input type="file" id="clientAvatar" name="clientAvatar" accept="image/*">
    </div>
    <button type="submit" class="btn-primary">Save Changes</button>
  </form>
</section>