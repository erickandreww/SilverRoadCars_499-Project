<% if (typeof title !== 'undefined' && title) { %>
  <h1><%= title %></h1>
<% } else { %>
  <h1>Client Profile</h1>
<% } %>

<% if (typeof error !== 'undefined' && error) { %>
  <p class="error"><%= error %></p>
<% } %>

<section class="clientProfile">
  <h2>Your Profile</h2>
  <p><strong>Name:</strong> <%= sessionUser.clientName %></p>
  <p><strong>Email:</strong> <%= sessionUser.clientEmail %></p>
  <p><strong>Phone:</strong> <%= sessionUser.clientPhone %></p>
  <p><strong>Address:</strong> <%= sessionUser.clientAddress %></p>
  <a href="/clients/profile/edit" class="btn-secondary">Edit Profile</a>
</section>