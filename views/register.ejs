<div class="auth-page">
  <div class="auth-card">
    <h1>Create Account</h1>

    <% if (error) { %>
      <p class="auth-error"><%= error %></p>
    <% } %>

    <form action="/register" method="POST" class="auth-form">
      <div class="form-group">
        <label for="clientName">Client Name</label>
        <input type="text" id="clientName" name="clientName" placeholder="Your name" required>
      </div>

      <div class="form-group">
        <label for="clientEmail">Email</label>
        <input type="email" id="clientEmail" name="clientEmail" placeholder="you@example.com" required>
      </div>

            <div class="form-group">
        <label for="clientPassword">Password</label>
        <input type="password" id="clientPassword" name="clientPassword" placeholder="Create a password" required>
      </div>

      <div class="form-group">
        <label for="confirmPassword">Confirm Password</label>
        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm your password" required>
      </div>

      <div class="form-group">
        <label for="clientAddress">Address</label>
        <input type="text" id="clientAddress" name="clientAddress" placeholder="Your address" required>
      </div>

      <div class="form-group">
        <label for="clientPhone">Phone</label>
        <input type="tel" id="clientPhone" name="clientPhone" placeholder="Your phone number" required>
      </div>

      <div class="form-group">
        <label for="driverLicenseNumber">DL Number</label>
        <input type="text" id="driverLicenseNumber" name="driverLicenseNumber" placeholder="Your driver license number" required>
      </div>

      <button type="submit" class="btn-primary">Create Account</button>
    </form>

    <p class="auth-switch">Already have an account? <a href="/login">Login</a></p>
  </div>
</div>
