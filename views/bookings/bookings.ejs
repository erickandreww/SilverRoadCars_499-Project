<% if (title) { %>
  <h1><%= title %></h1>
<% } %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<section class="admin-section admin-list-section">
  <div class="section-header">
    <h2>All Bookings</h2>

    <a href="/users/bookings/requests" class="btn-primary">
      View Pending Requests
    </a>
  </div>

  <% if (data && data.length > 0) { %>
    <table class="admin-table bookings-table">
      <thead>
        <tr>
          <th>Client</th>
          <th>Vehicle</th>
          <th>Dates</th>
          <th>Total Days</th>
          <th>Total Value</th>
          <th>Status</th>
          <th>Approved By</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        <% data.forEach(booking => { %>
          <tr>
            <td>
              <%= booking.clientName || "Unknown Client" %><br>
              <small><%= booking.clientEmail || "" %></small>
            </td>

            <td>
              <%= booking.brand %> <%= booking.model %><br>
              <small>Plate: <%= booking.plate || "N/A" %></small>
            </td>

            <td>
              <%= booking.startDate ? new Date(booking.startDate).toLocaleDateString() : "N/A" %>
              -
              <%= booking.endDate ? new Date(booking.endDate).toLocaleDateString() : "N/A" %>
            </td>

            <td><%= booking.totalDays || 0 %></td>

            <td>
              $<%= booking.totalValue || "0.00" %>
            </td>

            <td>
              <span class="status-badge status-<%= booking.bookingStatus %>">
                <%= booking.bookingStatus %>
              </span>
            </td>

            <td>
              <%= booking.approvedByName || "Not approved yet" %>
            </td>

            <td>
              <a href="/users/bookings/<%= booking.bookingId %>" class="table-action">
                Details
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p class="notice">No bookings were found.</p>
  <% } %>
  <%- include("../partials/pagination", { pagination }) %>
  <a href="/users" class="return-link">Return to Users Dashboard</a>
</section>