<% if (title) { %>
  <h1><%= title %></h1>
<% } %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<section class="admin-section">
  <h2>User Information</h2>

  <form class="admin-form editUser" action="/admin/users/update" method="post">
    <input type="hidden" name="userId" value="<%= userId %>">

    <label>Name
      <input type="text" name="userName" value="<%= userName %>" required>
    </label>

    <label>Email
      <input type="email" name="userEmail" value="<%= userEmail %>" required>
    </label>

    <label>Password
      <input type="password" name="userPassword" placeholder="Leave blank to keep current password">
    </label>

    <label>Role
      <select name="userRole" required>
        <option value="standard" <%= userRole === "standard" ? "selected" : "" %>>Standard</option>
        <option value="manager" <%= userRole === "manager" ? "selected" : "" %>>Manager</option>
      </select>
    </label>

    <button type="submit" class="btn-primary">Update User</button>
  </form>

  <form class="delete-form" action="/admin/users/delete" method="post">
    <input type="hidden" name="userId" value="<%= userId %>">

    <button
      type="submit"
      class="btn-danger"
      onclick="return confirm('Are you sure you want to delete this user?')"
    >
      Delete User
    </button>
  </form>
</section>