<section class="contact-page">
  <div class="contact-hero">
    <h1>Contact Us</h1>
    <p>Have a question or need help? Send us a message and we'll get back to you shortly.</p>
  </div>

  <div class="contact-layout">

    <div class="contact-info">
      <h2>Get in Touch</h2>
      <div class="contact-info-item">
        <span class="contact-icon">📍</span>
        <div>
          <strong>Address</strong>
          <p>123 Silver Road, Portland, OR 97201</p>
        </div>
      </div>
      <div class="contact-info-item">
        <span class="contact-icon">📞</span>
        <div>
          <strong>Phone</strong>
          <p>+1 (503) 555-0190</p>
        </div>
      </div>
      <div class="contact-info-item">
        <span class="contact-icon">✉️</span>
        <div>
          <strong>Email</strong>
          <p>support@silverroadcars.com</p>
        </div>
      </div>
      <div class="contact-info-item">
        <span class="contact-icon">🕐</span>
        <div>
          <strong>Hours</strong>
          <p>Mon – Fri: 8am – 6pm<br>Sat: 9am – 4pm</p>
        </div>
      </div>
    </div>

    <div class="contact-form-wrap">
      <% if (success) { %>
        <div class="contact-success">
          <h2>Message Sent!</h2>
          <p>Thanks for reaching out. We'll get back to you within 24 hours.</p>
          <a href="/contact" class="btn-primary">Send Another</a>
        </div>
      <% } else { %>

        <% if (error) { %>
          <p class="auth-error"><%= error %></p>
        <% } %>

        <form action="/contact" method="POST" class="auth-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input type="text" id="name" name="name" placeholder="Your name" required value="<%= formData.name || '' %>">
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required value="<%= formData.email || '' %>">
            </div>
          </div>

          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" placeholder="What is this about?" required value="<%= formData.subject || '' %>">
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="6" placeholder="Write your message here..." required><%= formData.message || '' %></textarea>
          </div>

          <button type="submit" class="btn-primary">Send Message</button>
        </form>
      <% } %>
    </div>

  </div>
</section>
